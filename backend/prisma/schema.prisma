enum NodeType {
  HOST
  ROUTER
  SWITCH
}

enum ProtocolType {
  TCP
  UDP
  ICMP
  ARP
}

enum Action {
  ALLOW
  DROP
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id          String   @id @db.Uuid @unique
  password    String   @db.VarChar(255)
  email       String   @db.VarChar(255)
}

model Topology {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  
  // Relations
  nodes       Node[]
  links       Link[]
  simulations SimulationSession[]

  @@map("topologies")
  @@index([createdAt])
}

model Node {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  type        NodeType
  positionX   Float    @db.DoublePrecision
  positionY   Float    @db.DoublePrecision
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  defaultGateway String?
  
  // Foreign Keys
  topologyId  String   @db.Uuid
  topology    Topology @relation(fields: [topologyId], references: [id], onDelete: Cascade)
  
  // Relations
  interfaces     NetworkInterface[]
  firewallRules  FirewallRule[]
  routingEntries RoutingEntry[]
  linksAsA       Link[]             @relation("LinkNodeA")
  linksAsB       Link[]             @relation("LinkNodeB")
  
  @@map("nodes")
  @@index([topologyId])
  @@index([type])
}

model NetworkInterface {
  id        String   @id @default(uuid()) @db.Uuid
  ip        String   @db.VarChar(15)
  mask      String   @db.VarChar(15)
  cidr      Int      @db.SmallInt
  mac       String   @db.VarChar(17)
  networkAddress   String   @db.VarChar(15)
  broadcastAddress String   @db.VarChar(15)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Foreign Keys
  nodeId    String   @db.Uuid
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  
  // Relations
  linksAsA  Link[]   @relation("LinkInterfaceA")
  linksAsB  Link[]   @relation("LinkInterfaceB")
  routes    RoutingEntry[]
  
  @@map("network_interfaces")
  @@index([nodeId])
  @@index([ip])
}

model Link {
  id           String   @id @default(uuid()) @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz
  
  // Foreign Keys
  topologyId   String             @db.Uuid
  topology     Topology           @relation(fields: [topologyId], references: [id], onDelete: Cascade)
  
  interfaceAId String             @db.Uuid
  interfaceA   NetworkInterface   @relation("LinkInterfaceA", fields: [interfaceAId], references: [id], onDelete: Cascade)
  
  interfaceBId String             @db.Uuid
  interfaceB   NetworkInterface   @relation("LinkInterfaceB", fields: [interfaceBId], references: [id], onDelete: Cascade)
  
  nodeAId      String             @db.Uuid
  nodeA        Node               @relation("LinkNodeA", fields: [nodeAId], references: [id], onDelete: Cascade)
  
  nodeBId      String             @db.Uuid
  nodeB        Node               @relation("LinkNodeB", fields: [nodeBId], references: [id], onDelete: Cascade)
  
  @@map("links")
  @@index([topologyId])
  @@unique([interfaceAId, interfaceBId])
}

model RoutingEntry {
  id          String   @id @default(uuid()) @db.Uuid
  destination String   @db.VarChar(15)
  mask        String   @db.VarChar(15)
  cidr        Int      @db.SmallInt
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz
  
  // Foreign Keys
  nodeId             String           @db.Uuid
  node               Node             @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  
  nextHopInterfaceId String           @db.Uuid
  nextHopInterface   NetworkInterface @relation(fields: [nextHopInterfaceId], references: [id], onDelete: Cascade)
  
  @@map("routing_entries")
  @@index([nodeId])
  @@index([isDefault])
}

model FirewallRule {
  id        String   @id @default(uuid()) @db.Uuid
  srcIp     String   @db.VarChar(15)  // "any" or specific IP
  dstIp     String   @db.VarChar(15)  // "any" or specific IP
  protocol  ProtocolType? // "ICMP" | "TCP" | "UDP" | null
  action    Action // "ALLOW" | "DROP"
  priority  Int      @db.Integer
  createdAt DateTime @default(now()) @db.Timestamptz
  
  // Foreign Keys
  nodeId    String   @db.Uuid
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  
  @@map("firewall_rules")
  @@index([nodeId])
  @@index([priority])
}

model SimulationSession {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  autoPopulateARP Boolean  @default(false)
  stepDelay       Int      @default(1000)
  status          String   @default("IDLE") // IDLE, RUNNING, COMPLETED, FAILED
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  // Relations
  topology   Topology @relation(fields: [topologyId], references: [id], onDelete: Cascade)
  topologyId String   @db.Uuid

  @@map("simulation_sessions")
  @@index([topologyId])
  @@index([status])
}